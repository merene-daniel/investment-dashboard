# ──────────────────────────────────────────────────────────────────────────────
# ARMOR — Environment variable template
#
# ✅ This file IS committed to git — it contains NO real secrets.
# Copy it to .env (gitignored) and fill in your own values.
#
#   cp .env.example .env
#
# ──────────────────────────────────────────────────────────────────────────────

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Option A — single Atlas connection string (takes precedence if set)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://danielmerene:dm0105@cluster0.nks6i.mongodb.net/investment_dashboard

# Option B — individual parts (used only when MONGODB_URI is empty)
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_CLUSTER=
MONGODB_DB=investment_dashboard

# ── Application ────────────────────────────────────────────────────────────────
# Runtime environment; Next.js sets this automatically — no need to change.
# NODE_ENV=development

# ── Public site URL ─────────────────────────────────────────────────────────────
# The canonical origin of your deployment (no trailing slash).
# Used for absolute links, Open Graph tags, canonical hrefs, and server-side fetch().
# Local dev:  http://localhost:3000
# Netlify:    https://your-site-name.netlify.app  (or your custom domain)
# IMPORTANT:  Set this in Netlify → Site Settings → Environment Variables
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Future additions ────────────────────────────────────────────────────────────
# Add new environment variables here with a description before adding to .env.
# EMAIL_FROM=noreply@armorinvest.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
